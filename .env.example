# Optional Docker image override for frontend runtime server.
# Use when Docker Hub is slow/unreachable in your region.
# BACKEND_PYTHON_IMAGE=mirror.gcr.io/library/python:3.12-slim
# FRONTEND_NGINX_IMAGE=mirror.gcr.io/library/nginx:alpine
# FRONTEND_NODE_IMAGE=mirror.gcr.io/library/node:20-alpine

# Defaults used by docker-compose.yml when unset.
BACKEND_PYTHON_IMAGE=python:3.12-slim
FRONTEND_NODE_IMAGE=node:20-alpine
FRONTEND_NGINX_IMAGE=nginx:alpine
